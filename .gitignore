# Secrets -- NEVER commit
.env
*.key
*.pem

# Python
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Data cache (large files)
data/*.parquet
data/*.csv

# Model artifacts (large binary files)
models/*.keras
models/*.h5
models/*.joblib
checkpoints/

# Keep model metadata (small JSON/CSV)
!models/*_meta.json
!models/*_training_log.csv

# Logs (large, regenerable)
logs/*.log
logs/*.jsonl

# Benchmark per-run scorecards (regenerable from candidate+spec+frozen data).
# NOTE: benchmark/snapshots/ is intentionally NOT ignored so the frozen, hash-
# verified data is committed and every machine judges on identical bytes.
benchmark/results/

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# Deploy
.deploy_package/

# Sweep snapshots: full-history parquet is large (~320MB). Rebuildable from the
# committed manifest (hashes) via `python -m sweep.build_data`. Keep manifest, ignore parquet.
sweep/snapshots/*.parquet

# Phase 2/3 research panels: large parquet, rebuildable from manifest
phase2/snapshots/*.parquet
